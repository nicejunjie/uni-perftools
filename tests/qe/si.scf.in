 &control
    calculation = 'scf'
    prefix = 'si'
    pseudo_dir = './pseudo/'
    outdir = './scratch/'
    tstress = .true.
    tprnfor = .true.
 /
 &system
    ibrav = 2, celldm(1) = 10.26, nat = 2, ntyp = 1,
    ecutwfc = 40.0,
 /
 &electrons
    mixing_beta = 0.7
    conv_thr = 1.0d-8
 /
ATOMIC_SPECIES
 Si  28.0855  Si.pz-vbc.UPF
ATOMIC_POSITIONS alat
 Si 0.00 0.00 0.00
 Si 0.25 0.25 0.25
K_POINTS automatic
 8 8 8 1 1 1
