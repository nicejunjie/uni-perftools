#!/usr/bin/env python3
"""upat — the deep-tier command of Universal Performance Tools (uni-perftools).

Universal Performance Analysis Tool (← CrayPAT): library tracing (BLAS/LAPACK/
FFTW/MPI/IO), call-stack sampling, per-function roofline, I/O, heap. Injected
into the target via LD_PRELOAD; emits prof.<rank>.json and renders the report.

For the cheap, non-invasive bird's-eye snapshot (HWPC + MPI/OpenMP, APS-style),
run the OTHER command — `uaps` — instead. The two are cost tiers; run one.

  upat run     -- ./app                 # profile + report (one-liner)
  upat run     -- mpirun -n 4 ./app
  upat collect -o RESULT -- ./app       # just collect into RESULT
  upat report  [RESULT]                 # render (default: most recent)
  upat roofline -- ./app                # per-function roofline (event sampling)
  upat scale   R1 R2 ...                # scaling across runs
"""
import os
import sys
import json
import argparse
import subprocess

HERE = os.path.dirname(os.path.abspath(__file__))
ROOT = os.path.dirname(os.path.dirname(HERE))             # repo root
sys.path.insert(0, os.path.join(ROOT, "core", "contract"))
sys.path.insert(0, os.path.join(ROOT, "core", "analysis"))
import contract       # noqa: E402
import report         # noqa: E402


def find(env, cands):
    if os.environ.get(env):
        return os.environ[env]
    for c in cands:
        if c and os.path.exists(c):
            return c
    return None


def profile_lib(dbi):
    return find("PROFILE_LIB", [os.path.join(
        ROOT, "collectors", "profile",
        "libupat-%s.so" % ("frida" if dbi else "preload"))])


def scoped(cmd, env_vars):
    """Scope env to the TARGET only (keep it out of the snapshot collector)."""
    launcher = os.path.basename(cmd[0]) if cmd else ""
    kv = ["%s=%s" % (k, v) for k, v in env_vars.items()]
    if launcher in ("mpirun", "mpiexec", "orterun"):
        inj = []
        for x in kv:
            inj += ["-x", x]
        return [cmd[0]] + inj + cmd[1:]
    return ["env"] + kv + cmd


def do_collect(args):
    lib = profile_lib(args.dbi)
    if not lib:
        sys.exit("upat: profile .so not found (build collectors/profile or set PROFILE_LIB)")
    result = args.outdir or os.path.join(os.getcwd(), "perf.%d" % os.getpid())
    os.makedirs(result, exist_ok=True)

    env_vars = {"LD_PRELOAD": lib, "UPAT_OUTPUT": os.path.join(result, "prof"),
                "UPAT_QUIET": "1",
                "UPAT_SHAPE": "1"}   # size-resolved rows for --detail
    if args.no_sample:
        env_vars["UPAT_SAMPLE"] = "0"
    if args.heap:
        env_vars["UPAT_HEAP"] = "1"
    if getattr(args, "roofline", False):
        # characterize pass: FP-op + DRAM-fill event sampling for per-function roofline
        env_vars["UPAT_ROOFLINE"] = "1"
        env_vars["UPAT_SAMPLE"] = "1"
        env_vars["UPAT_SAMPLE_STACK"] = "1"

    # profile only — upat injects via LD_PRELOAD. The snapshot tier is the
    # separate `uaps` command; run it on its own (cost tiers, not combined).
    full = scoped(args.cmd, env_vars)

    json.dump({"schema_version": contract.SCHEMA_VERSION, "command": args.cmd,
               "collectors": ["profile"]},
              open(os.path.join(result, contract.MANIFEST), "w"), indent=2)

    sys.stderr.write("[upat] collecting: %s\n" % " ".join(args.cmd))
    rc = subprocess.run(full).returncode
    return result, rc


def main():
    ap = argparse.ArgumentParser(prog="upat")
    sub = ap.add_subparsers(dest="verb", required=True)
    VIEWS = ["all", "hotspots", "roofline", "roofline-func", "microarch", "memory",
             "imbalance", "threading", "mpi", "mpi-summary", "vectorization", "anomaly"]
    for name in ("collect", "run", "roofline"):
        p = sub.add_parser(name, help="per-function roofline (FP/DRAM event sampling)"
                           if name == "roofline" else None)
        p.add_argument("--dbi", action="store_true", help="profile via Frida backend")
        p.add_argument("--no-sample", action="store_true")
        p.add_argument("--heap", action="store_true")
        if name != "roofline":
            p.add_argument("--roofline", action="store_true",
                           help="also sample FP/DRAM events for per-function roofline")
        p.add_argument("-o", "--outdir")
        p.add_argument("--format", default="text", choices=["text", "json", "html"])
        p.add_argument("--view", default="all", choices=VIEWS)
        p.add_argument("--threshold", type=float, default=0.1,
                       help="hide functions below this %% of runtime (default 0.1; 0 = all)")
        p.add_argument("cmd", nargs=argparse.REMAINDER)
    rp = sub.add_parser("report")
    rp.add_argument("result", nargs="?")
    rp.add_argument("--format", default="text", choices=["text", "json", "html"])
    rp.add_argument("--view", default="all", choices=VIEWS)
    rp.add_argument("--threshold", type=float, default=0.1,
                    help="hide functions below this %% of runtime (default 0.1; 0 = show all)")
    rp.add_argument("--collector", default="both", choices=["both", "uaps", "upat"],
                    help="render only one collector's report")
    rp.add_argument("--detail", choices=["blas", "lapack", "fftw", "mpi", "io"],
                    help="per-facility detail analysis (per-shape calls / MPI comm matrix)")
    rp.add_argument("-o", "--outdir",
                    help="write report files into this dir (text: report.uaps/upat.txt; "
                         "html: report.html or report.<detail>.html)")
    sc = sub.add_parser("scale", help="compare multiple results (scaling analysis)")
    sc.add_argument("results", nargs="+")

    # implicit `run`: `upat ./app` / `upat --no-sample ./app` == `upat run …`
    VERBS = ("collect", "run", "report", "roofline", "scale")
    if len(sys.argv) > 1 and sys.argv[1] not in VERBS and sys.argv[1] not in ("-h", "--help"):
        sys.argv.insert(1, "run")

    args = ap.parse_args()
    if args.verb in ("collect", "run", "roofline"):
        if args.verb == "roofline":
            args.roofline = True                 # the verb forces the characterize pass
        if args.cmd and args.cmd[0] == "--":
            args.cmd = args.cmd[1:]
        if not args.cmd:
            ap.error("no command (use: upat %s -- <command>)" % args.verb)
        result, rc = do_collect(args)
        if args.verb == "collect":
            sys.stderr.write("[upat] result: %s  (upat report %s)\n" % (result, result))
        else:
            report.render(result, args.format, args.view, threshold=args.threshold)
        sys.exit(rc)
    elif args.verb == "scale":
        import scaling
        scaling.render(args.results)
    else:
        result = args.result or contract.latest_result()
        if not result:
            sys.exit("upat: no result dir given and none found")
        if args.outdir and args.format in ("text", "html"):
            os.makedirs(args.outdir, exist_ok=True)
            ext = "html" if args.format == "html" else "txt"
            name = "report.%s.%s" % (args.detail, ext) if args.detail else "report.%s" % ext
            path = os.path.join(args.outdir, name)
            # redirect fd 1 (not just sys.stdout) so the upat-report subprocess
            # output lands in the file too
            f = open(path, "w")
            saved = os.dup(1)
            try:
                sys.stdout.flush()
                os.dup2(f.fileno(), 1)
                report.render(result, args.format, args.view, collector=args.collector,
                              detail=args.detail, threshold=args.threshold)
                sys.stdout.flush()
            finally:
                os.dup2(saved, 1)
                os.close(saved)
                f.close()
            sys.stderr.write("[upat] wrote %s\n" % path)
        else:
            report.render(result, args.format, args.view,
                          collector=args.collector, detail=args.detail, threshold=args.threshold)


if __name__ == "__main__":
    main()
