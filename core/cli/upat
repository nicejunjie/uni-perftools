#!/usr/bin/env python3
"""upat — the deep-tier command of the Universal Performance Tool Suite (uni-perftools).

Universal Performance Analysis Tool (← CrayPAT): library tracing (BLAS/LAPACK/
FFTW/MPI/IO), call-stack sampling, per-function roofline, I/O, heap. Injected
into the target via LD_PRELOAD; emits prof.<rank>.json and renders the report.

For the cheap, non-invasive bird's-eye snapshot (HWPC + MPI/OpenMP, APS-style),
run the OTHER command — `uaps` — instead. The two are cost tiers; run one.

  upat run     -- ./app                 # profile + report (one-liner)
  upat run     -- mpirun -n 4 ./app
  upat collect -o RESULT -- ./app       # just collect into RESULT
  upat report  [RESULT]                 # render (default: most recent)
  upat roofline -- ./app                # per-function roofline (event sampling)
  upat scale   R1 R2 ...                # scaling across runs
"""
import os
import sys
import json
import argparse
import subprocess

HERE = os.path.dirname(os.path.abspath(__file__))
ROOT = os.path.dirname(os.path.dirname(HERE))             # repo root
sys.path.insert(0, os.path.join(ROOT, "core", "contract"))
sys.path.insert(0, os.path.join(ROOT, "core", "analysis"))
sys.path.insert(0, os.path.join(ROOT, "core", "roofline"))
import contract       # noqa: E402
import report         # noqa: E402
import roofline       # noqa: E402


def find(env, cands):
    if os.environ.get(env):
        return os.environ[env]
    for c in cands:
        if c and os.path.exists(c):
            return c
    return None


def profile_lib(dbi):
    return find("PROFILE_LIB", [os.path.join(
        ROOT, "collectors", "profile",
        "libupat-%s.so" % ("frida" if dbi else "preload"))])


# Per-function roofline needs two semantic quantities — FLOPs and DRAM bytes —
# attributed to a sampled PC. The *events* that carry them differ by vendor, but
# their codes all live in perf's vendored pmu-events db, so we resolve them
# data-drivenly (via `uaps resolve-events`) instead of hard-coding. Each entry is
# (event_name, weight): weight = flops/op for FP (Intel splits FP by width, so the
# umasks weight 1/2/4/8), bytes/sample for the DRAM-access event (a cache line).
# ARM FP events are speculative-counted (a known accuracy caveat, not a gap).
ROOFLINE_EVENTS = {
    # AMD DRAM bytes use the prefetch-inclusive L2-from-DRAM fills (near+far,
    # summed) — the SAME source as the snapshot's dram_bandwidth_gbs ceiling. The
    # demand-only ls_dmnd_fills counter undercounts streaming traffic ~3x, which
    # would place memory-bound functions ~3x too high in arithmetic intensity
    # relative to the bandwidth roof they are drawn against.
    "amd": ([("fp_ret_sse_avx_ops.all", 1.0)],
            [("l2_fill_rsp_src.dram_io_near", 64.0),
             ("l2_fill_rsp_src.dram_io_far", 64.0)]),
    "intel": ([("FP_ARITH_INST_RETIRED.SCALAR_DOUBLE", 1.0),
               ("FP_ARITH_INST_RETIRED.128B_PACKED_DOUBLE", 2.0),
               ("FP_ARITH_INST_RETIRED.256B_PACKED_DOUBLE", 4.0),
               ("FP_ARITH_INST_RETIRED.512B_PACKED_DOUBLE", 8.0)],
              [("MEM_LOAD_RETIRED.L3_MISS", 64.0)]),
    "arm": ([("FP_SCALE_OPS_SPEC", 1.0), ("FP_FIXED_OPS_SPEC", 1.0)],
            [("LL_CACHE_MISS_RD", 64.0)]),
}


def _cpu_vendor():
    """'amd' | 'intel' | 'arm' from /proc/cpuinfo, else None."""
    try:
        info = open("/proc/cpuinfo").read()
    except OSError:
        return None
    if "AuthenticAMD" in info:
        return "amd"
    if "GenuineIntel" in info:
        return "intel"
    if "CPU implementer" in info:   # arm64 cpuinfo has no vendor_id
        return "arm"
    return None


def find_uaps():
    return find("UAPS", [os.path.join(ROOT, "collectors", "snapshot", "target", c, "uaps")
                         for c in ("release", "debug")])


def roofline_spec():
    """Resolve this host's roofline FP/DRAM events to a UPAT_ROOFLINE_SPEC string
    (`role,config,period,scale;...`) via the uaps pmu-events resolver. Returns None
    if the vendor/events/resolver are unavailable — the C sampler then falls back to
    its built-in AMD codes (or stays off on non-AMD), so behaviour degrades, never
    breaks."""
    vendor = _cpu_vendor()
    uaps = find_uaps()
    if not vendor or vendor not in ROOFLINE_EVENTS or not uaps:
        return None
    fp_list, mem_list = ROOFLINE_EVENTS[vendor]
    fp_p = os.environ.get("UPAT_ROOFLINE_FP_PERIOD", "1000000")
    mem_p = os.environ.get("UPAT_ROOFLINE_MEM_PERIOD", "10000")
    names = [n for n, _ in fp_list] + [n for n, _ in mem_list]
    try:
        out = subprocess.run([uaps, "resolve-events", *names],
                             capture_output=True, text=True, timeout=30)
    except (OSError, subprocess.SubprocessError):
        return None
    cfg = {}
    for line in out.stdout.splitlines():
        if "=" in line:
            k, v = line.split("=", 1)
            cfg[k] = v.strip()        # "0xCONFIG:TYPE" or "GAP"
    def conf(name):
        v = cfg.get(name, "GAP")
        if v == "GAP" or ":" not in v:
            return None
        config, _, ty = v.partition(":")   # type = perf_event_attr.type
        return ty, config
    # spec channel: role,type,config,period,scale
    chans = []
    for name, w in fp_list:
        cv = conf(name)
        if cv:
            chans.append("fp,%s,%s,%s,%g" % (cv[0], cv[1], fp_p, w))
    for name, w in mem_list:
        cv = conf(name)
        if cv:
            chans.append("mem,%s,%s,%s,%g" % (cv[0], cv[1], mem_p, w))
    # need at least one FP channel for a meaningful roofline
    return ";".join(chans) if any(ch.startswith("fp,") for ch in chans) else None


def scoped(cmd, env_vars):
    """Scope env to the TARGET only (keep it out of the snapshot collector)."""
    launcher = os.path.basename(cmd[0]) if cmd else ""
    kv = ["%s=%s" % (k, v) for k, v in env_vars.items()]
    if launcher in ("mpirun", "mpiexec", "orterun"):
        inj = []
        for x in kv:
            inj += ["-x", x]
        return [cmd[0]] + inj + cmd[1:]
    if launcher == "srun":
        # srun propagates env to ranks via --export (ALL keeps the inherited env).
        return [cmd[0], "--export=ALL," + ",".join(kv)] + cmd[1:]
    if launcher:
        sys.stderr.write("[upat] warning: unrecognized launcher '%s' — env (LD_PRELOAD/"
                         "UPAT_*) may not propagate to ranks\n" % launcher)
    return ["env"] + kv + cmd


def do_collect(args):
    lib = profile_lib(args.dbi)
    if not lib:
        sys.exit("upat: profile .so not found (build collectors/profile or set PROFILE_LIB)")
    result = args.outdir or os.path.join(os.getcwd(), "perf.%d" % os.getpid())
    os.makedirs(result, exist_ok=True)

    env_vars = {"LD_PRELOAD": lib, "UPAT_OUTPUT": os.path.join(result, "prof"),
                "UPAT_QUIET": "1",
                "UPAT_SHAPE": "1"}   # size-resolved rows for --detail
    if args.no_sample:
        env_vars["UPAT_SAMPLE"] = "0"
    if args.heap:
        env_vars["UPAT_HEAP"] = "1"
    if getattr(args, "roofline", False):
        # characterize pass: FP + DRAM-access event sampling for per-function roofline
        env_vars["UPAT_ROOFLINE"] = "1"
        env_vars["UPAT_SAMPLE"] = "1"
        env_vars["UPAT_SAMPLE_STACK"] = "1"
        # Resolve the vendor's FP/DRAM events from pmu-events (cross-platform);
        # the C sampler falls back to built-in AMD codes if we can't.
        spec = roofline_spec()
        if spec:
            env_vars["UPAT_ROOFLINE_SPEC"] = spec
        else:
            sys.stderr.write("[upat] roofline: no resolved event spec for this host"
                             " — using sampler's built-in fallback (AMD only)\n")

    # profile only — upat injects via LD_PRELOAD. The snapshot tier is the
    # separate `uaps` command; run it on its own (cost tiers, not combined).
    full = scoped(args.cmd, env_vars)

    json.dump({"schema_version": contract.SCHEMA_VERSION, "command": args.cmd,
               "collectors": ["profile"]},
              open(os.path.join(result, contract.MANIFEST), "w"), indent=2)

    sys.stderr.write("[upat] collecting: %s\n" % " ".join(args.cmd))
    try:
        rc = subprocess.run(full).returncode
    except FileNotFoundError:
        sys.stderr.write("upat: cannot exec %s\n" % full[0])
        sys.exit(127)

    # Recalibrate the roofline ceilings on THIS host and store them with the run,
    # so the report reflects the machine the workload ran on (not a stale build
    # cache that may have been calibrated on a different CPU).
    try:
        roofline.calibrate_into(result)
    except Exception:
        pass
    return result, rc


def main():
    ap = argparse.ArgumentParser(prog="upat")
    sub = ap.add_subparsers(dest="verb", required=True)
    VIEWS = ["all", "hotspots", "roofline", "roofline-func", "microarch", "memory",
             "imbalance", "threading", "mpi", "mpi-summary", "vectorization", "anomaly"]
    for name in ("collect", "run", "roofline"):
        p = sub.add_parser(name, help="per-function roofline (FP/DRAM event sampling)"
                           if name == "roofline" else None)
        p.add_argument("--dbi", action="store_true", help="profile via Frida backend")
        p.add_argument("--no-sample", action="store_true")
        p.add_argument("--heap", action="store_true")
        if name != "roofline":
            p.add_argument("--roofline", action="store_true",
                           help="also sample FP/DRAM events for per-function roofline")
        p.add_argument("-o", "--outdir")
        p.add_argument("--format", default="text", choices=["text", "json", "html"])
        p.add_argument("--view", default="all", choices=VIEWS)
        p.add_argument("--threshold", type=float, default=0.1,
                       help="hide functions below this %% of runtime (default 0.1; 0 = all)")
        p.add_argument("cmd", nargs=argparse.REMAINDER)
    rp = sub.add_parser("report")
    rp.add_argument("result", nargs="?")
    rp.add_argument("--format", default="text", choices=["text", "json", "html"])
    rp.add_argument("--view", default="all", choices=VIEWS)
    rp.add_argument("--threshold", type=float, default=0.1,
                    help="hide functions below this %% of runtime (default 0.1; 0 = show all)")
    rp.add_argument("--collector", default=None, choices=["uaps", "upat"],
                    help="which cost tier to report (default: auto — upat if a profile is "
                         "present, else the uaps snapshot; the tiers are never combined)")
    rp.add_argument("--detail", choices=["blas", "lapack", "fftw", "mpi", "io"],
                    help="per-facility detail analysis (per-shape calls / MPI comm matrix)")
    rp.add_argument("-o", "--outdir",
                    help="write report files into this dir (text: report.uaps/upat.txt; "
                         "html: report.html or report.<detail>.html)")
    sc = sub.add_parser("scale", help="compare multiple results (scaling analysis)")
    sc.add_argument("results", nargs="+")

    # implicit `run`: `upat ./app` / `upat --no-sample ./app` == `upat run …`
    VERBS = ("collect", "run", "report", "roofline", "scale")
    if len(sys.argv) > 1 and sys.argv[1] not in VERBS and sys.argv[1] not in ("-h", "--help"):
        sys.argv.insert(1, "run")

    args = ap.parse_args()
    if args.verb in ("collect", "run", "roofline"):
        if args.verb == "roofline":
            args.roofline = True                 # the verb forces the characterize pass
        if args.cmd and args.cmd[0] == "--":
            args.cmd = args.cmd[1:]
        if not args.cmd:
            ap.error("no command (use: upat %s -- <command>)" % args.verb)
        result, rc = do_collect(args)
        if args.verb == "collect":
            sys.stderr.write("[upat] result: %s  (upat report %s)\n" % (result, result))
        else:
            report.render(result, args.format, args.view, threshold=args.threshold)
        sys.exit(rc)
    elif args.verb == "scale":
        import scaling
        scaling.render(args.results)
    else:
        result = args.result or contract.latest_result()
        if not result:
            sys.exit("upat: no result dir given and none found")
        # No combined report: pick the single tier to render. Explicit --collector
        # wins; otherwise auto — a deep profile if one was recorded, else the snapshot.
        coll = args.collector or ("upat" if contract.prof_glob(result) else "uaps")
        args.collector = coll
        if args.outdir and args.format in ("text", "html"):
            os.makedirs(args.outdir, exist_ok=True)
            ext = "html" if args.format == "html" else "txt"
            name = ("detail.%s.%s" % (args.detail, ext) if args.detail
                    else "%s.%s" % (coll, ext))
            path = os.path.join(args.outdir, name)
            # redirect fd 1 (not just sys.stdout) so the upat-report subprocess
            # output lands in the file too
            f = open(path, "w")
            saved = os.dup(1)
            try:
                sys.stdout.flush()
                os.dup2(f.fileno(), 1)
                report.render(result, args.format, args.view, collector=args.collector,
                              detail=args.detail, threshold=args.threshold)
                sys.stdout.flush()
            finally:
                os.dup2(saved, 1)
                os.close(saved)
                f.close()
            sys.stderr.write("[upat] wrote %s\n" % path)
        else:
            report.render(result, args.format, args.view,
                          collector=args.collector, detail=args.detail, threshold=args.threshold)


if __name__ == "__main__":
    main()
