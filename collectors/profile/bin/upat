#!/usr/bin/env python3
"""upat - one-command driver (CrayPAT pat_run style).

    upat ./app                 # run + auto-report
    upat mpirun -n 4 ./app     # parallel; LD_PRELOAD propagated
    upat --dbi ./static_app    # use the Frida (static-lib) backend
    upat --no-sample ./app     # tracing only (no PC sampling)

Sets LD_PRELOAD + UPAT_* for the child, runs it, then symbolizes/aggregates the
per-rank raw files into one report. No recompilation, no manual postprocess step.
"""
import sys, os, glob, shutil, tempfile, argparse, subprocess

HERE = os.path.dirname(os.path.abspath(__file__))
ROOT = os.path.dirname(HERE)


def find(cands):
    for c in cands:
        if c and os.path.exists(c):
            return c
    return None


def main():
    ap = argparse.ArgumentParser(usage="upat [opts] <command...>", add_help=True)
    ap.add_argument("--dbi", action="store_true", help="use the Frida backend (static libs)")
    ap.add_argument("--no-sample", action="store_true", help="disable PC sampling")
    ap.add_argument("--shape", action="store_true", help="per-shape rows (size-resolved)")
    ap.add_argument("-o", "--outdir", help="keep raw per-rank files in this directory")
    ap.add_argument("--imbalance", choices=["active", "world"], default="active")
    ap.add_argument("--top", type=int, default=0)
    ap.add_argument("cmd", nargs=argparse.REMAINDER, help="the command to profile")
    args = ap.parse_args()
    if not args.cmd:
        ap.error("no command given")

    lib_name = "libupat-frida.so" if args.dbi else "libupat-preload.so"
    lib = find([os.path.join(ROOT, "lib", lib_name), os.path.join(ROOT, lib_name),
                os.path.join(HERE, lib_name)])
    report = find([os.path.join(HERE, "upat-report"), os.path.join(HERE, "upat-report.py"),
                   os.path.join(ROOT, "tools", "upat-report.py")])
    if not lib:
        sys.exit("upat: cannot find %s (run make)" % lib_name)
    if not report:
        sys.exit("upat: cannot find upat-report")

    tmp = None
    outdir = args.outdir
    if not outdir:
        tmp = tempfile.mkdtemp(prefix="upat-")
        outdir = tmp
    else:
        os.makedirs(outdir, exist_ok=True)
    prefix = os.path.join(outdir, "prof")

    env = os.environ.copy()
    env["LD_PRELOAD"] = (lib + " " + env.get("LD_PRELOAD", "")).strip()
    env["UPAT_OUTPUT"] = prefix
    env["UPAT_QUIET"] = "1"
    env["UPAT_SAMPLE"] = "0" if args.no_sample else "1"
    if args.shape:
        env["UPAT_SHAPE"] = "1"

    # Make sure the launcher forwards our env to the ranks (OpenMPI needs -x).
    cmd = list(args.cmd)
    launcher = os.path.basename(cmd[0])
    if launcher in ("mpirun", "mpiexec", "orterun"):
        inj = []
        for v in ("LD_PRELOAD", "UPAT_OUTPUT", "UPAT_QUIET", "UPAT_SAMPLE", "UPAT_SHAPE"):
            if v in env:
                inj += ["-x", v]
        cmd = [cmd[0]] + inj + cmd[1:]

    sys.stderr.write("[upat] profiling: %s\n" % " ".join(args.cmd))
    rc = subprocess.run(cmd, env=env).returncode

    files = sorted(glob.glob(prefix + ".*.json"))
    if not files:
        sys.stderr.write("[upat] no profile data was produced.\n")
    else:
        subprocess.run([sys.executable, report, "--imbalance", args.imbalance,
                        "--top", str(args.top)] + files)
    if tmp:
        shutil.rmtree(tmp, ignore_errors=True)
    sys.exit(rc)


if __name__ == "__main__":
    main()
